{
  "name": "vue-effect",
  "version": "0.1.0",
  "description": "A lightweight Vue 3 library starter.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vue-effect.cjs",
  "module": "./dist/vue-effect.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-effect.js",
      "require": "./dist/vue-effect.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.4.0 || ^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.16",
    "vue-tsc": "^2.2.10",
    "typescript": "^5.8.3"
  }
}
